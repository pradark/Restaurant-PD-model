 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Rx PD Model - Final with Feature Engineering + RFE\n",
    "## Advanced Rolling Features + Recursive Feature Elimination"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install -q --upgrade pandas numpy scikit-learn matplotlib seaborn"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import zipfile\n",
    "import os\n",
    "import seaborn as sns\n",
    "import matplotlib.pyplot as plt\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "from datetime import timedelta\n",
    "\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.ensemble import GradientBoostingClassifier, RandomForestClassifier\n",
    "from sklearn.feature_selection import RFE\n",
    "from sklearn.metrics import roc_auc_score, accuracy_score, balanced_accuracy_score, precision_score, recall_score, confusion_matrix\n",
    "\n",
    "sns.set_style('whitegrid')\n",
    "plt.rcParams['figure.figsize'] = [12, 8]\n",
    "plt.rcParams['figure.dpi'] = 100\n",
    "\n",
    "print('✓ Libraries imported')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Step 1: Extract and Load Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Extract\n",
    "for zip_file in ['Lending_default_train.zip', 'Lending_default_holdout.zip']:\n",
    "    if os.path.exists(zip_file):\n",
    "        with zipfile.ZipFile(zip_file, 'r') as z:\n",
    "            z.extractall()\n",
    "        print(f'✓ {zip_file}')\n",
    "\n",
    "# Load\n",
    "df_train_tx = pd.read_csv('Lending_default_train_tx.csv')\n",
    "df_train_acc = pd.read_csv('Lending_default_train_account.csv')\n",
    "df_train_label = pd.read_csv('Lending_default_train_label.csv')\n",
    "df_holdout_tx = pd.read_csv('Lending_default_holdout_tx.csv')\n",
    "df_holdout_acc = pd.read_csv('Lending_default_holdout_account.csv')\n",
    "\n",
    "# Clean\n",
    "for df in [df_train_tx, df_train_acc, df_train_label, df_holdout_tx, df_holdout_acc]:\n",
    "    cols = [c for c in df.columns if c.startswith('Unnamed')]\n",
    "    df.drop(columns=cols, inplace=True)\n",
    "\n",
    "print(f'✓ Data loaded')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Step 2: Feature Engineering - Rolling Time-Series"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def engineer_rolling_features(tx_data, snapshot_date_str):\n    \"\"\"\n    Create rolling time-series features: 7d, 30d, 120d, 180d windows\n    \"\"\"\n    snapshot_date = pd.to_datetime(snapshot_date_str)\n    windows = [7, 30, 120, 180]\n    df_features = None\n    \n    for window_days in windows:\n        cutoff_date = snapshot_date - timedelta(days=window_days)\n        window_data = tx_data[\n            (tx_data['Tx_date'] >= str(cutoff_date.date())) & \n            (tx_data['Tx_date'] <= snapshot_date_str)\n        ].copy()\n        \n        window_features = window_data.groupby('Restaurant_ID').agg({\n            'processing_volume': ['mean', 'min', 'max', 'std'],\n            'Tx_hours': ['mean', 'min', 'max', 'std']\n        }).reset_index()\n        \n        window_features.columns = ['Restaurant_ID',\n                                   f'avg_proc_vol_{window_days}d',\n                                   f'min_proc_vol_{window_days}d',\n                                   f'max_proc_vol_{window_days}d',\n                                   f'std_proc_vol_{window_days}d',\n                                   f'avg_tx_hours_{window_days}d',\n                                   f'min_tx_hours_{window_days}d',\n                                   f'max_tx_hours_{window_days}d',\n                                   f'std_tx_hours_{window_days}d']\n        \n        # CV: coefficient of variation\n        window_features[f'cv_proc_vol_{window_days}d'] = (\n            window_features[f'std_proc_vol_{window_days}d'] / \n            window_features[f'avg_proc_vol_{window_days}d']\n        ).fillna(0).replace([np.inf, -np.inf], 0)\n        \n        window_features[f'cv_tx_hours_{window_days}d'] = (\n            window_features[f'std_tx_hours_{window_days}d'] / \n            window_features[f'avg_tx_hours_{window_days}d']\n        ).fillna(0).replace([np.inf, -np.inf], 0)\n        \n        # Drop std (keep CV instead)\n        window_features.drop(\n            columns=[f'std_proc_vol_{window_days}d', f'std_tx_hours_{window_days}d'],\n            inplace=True\n        )\n        \n        if df_features is None:\n            df_features = window_features\n        else:\n            df_features = df_features.merge(window_features, on='Restaurant_ID', how='outer')\n    \n    return df_features\n\ndef add_temporal_features(tx_data, features_df):\n    \"\"\"\n    Add snapshot date features: day_of_week, day_of_year, month, quarter\n    \"\"\"\n    latest_dates = tx_data.groupby('Restaurant_ID')['Tx_date'].max().reset_index()\n    latest_dates.rename(columns={'Tx_date': 'snapshot_date'}, inplace=True)\n    latest_dates['snapshot_date'] = pd.to_datetime(latest_dates['snapshot_date'])\n    \n    latest_dates['snapshot_day_of_week'] = latest_dates['snapshot_date'].dt.dayofweek + 1\n    latest_dates['snapshot_day_of_year'] = latest_dates['snapshot_date'].dt.dayofyear\n    latest_dates['snapshot_month'] = latest_dates['snapshot_date'].dt.month\n    latest_dates['snapshot_quarter'] = latest_dates['snapshot_date'].dt.quarter\n    \n    features_df = features_df.merge(\n        latest_dates[['Restaurant_ID', 'snapshot_day_of_week', 'snapshot_day_of_year', \n                      'snapshot_month', 'snapshot_quarter']],\n        on='Restaurant_ID', how='left'\n    )\n    \n    return features_df\n\nprint('Feature engineering functions defined')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Engineer features\nprint('='*80)\nprint('FEATURE ENGINEERING')\nprint('='*80)\n\nprint(f'\\nTraining data snapshot date: {df_train_tx[\"Tx_date\"].max()}')\ndf_train_rolling = engineer_rolling_features(df_train_tx, df_train_tx['Tx_date'].max())\ndf_train_features = add_temporal_features(df_train_tx, df_train_rolling)\n\nprint(f'Holdout data snapshot date: {df_holdout_tx[\"Tx_date\"].max()}')\ndf_holdout_rolling = engineer_rolling_features(df_holdout_tx, df_holdout_tx['Tx_date'].max())\ndf_holdout_features = add_temporal_features(df_holdout_tx, df_holdout_rolling)\n\nprint(f'\\nTraining features: {df_train_features.shape}')\nprint(f'Holdout features: {df_holdout_features.shape}')\nprint(f'\\nFeature columns:')\nfor col in df_train_features.columns:\n    print(f'  - {col}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Step 3: Merge with Account Data and Target"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Merge training\ndf_train_final = df_train_features.merge(df_train_acc, on='Restaurant_ID', how='inner')\ndf_train_final = df_train_final.merge(df_train_label, on='Restaurant_ID', how='inner')\n\n# Merge holdout\ndf_holdout_final = df_holdout_features.merge(df_holdout_acc, on='Restaurant_ID', how='inner')\n\nprint(f'Training final: {df_train_final.shape}')\nprint(f'Holdout final: {df_holdout_final.shape}')\nprint(f'\\nEvent rate: {df_train_final[\"loan_default\"].mean()*100:.2f}%')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Step 4: 80/20 Train-Test Split"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "y = df_train_final['loan_default']\nX = df_train_final.drop(columns=['loan_default', 'Restaurant_ID', 'Tx_date'] + \n                                  [c for c in df_train_final.columns if 'Ownership' in c or 'catagory' in c or 'segment' in c])\n\n# Add categorical features encoded\nfor col in ['Ownership_type', 'Restaurant_catagory', 'Market_segment']:\n    if col in df_train_final.columns:\n        dummies = pd.get_dummies(df_train_final[col], prefix=col)\n        X = pd.concat([X, dummies], axis=1)\n\nX_train, X_test, y_train, y_test = train_test_split(\n    X, y, test_size=0.20, stratify=y, random_state=42\n)\n\ndf_train_set = X_train.copy()\ndf_train_set['loan_default'] = y_train.values\ndf_test_set = X_test.copy()\ndf_test_set['loan_default'] = y_test.values\n\nprint('='*80)\nprint('80/20 TRAIN-TEST SPLIT')\nprint('='*80)\nprint(f'Training: {len(X_train):,} ({len(X_train)/len(X)*100:.1f}%)')\nprint(f'Test: {len(X_test):,} ({len(X_test)/len(X)*100:.1f}%)')\nprint(f'\\nEvent rates:')\nprint(f'  Train: {y_train.mean()*100:.2f}%')\nprint(f'  Test: {y_test.mean()*100:.2f}%')\nprint(f'\\nTotal features: {X_train.shape[1]}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Step 5: Recursive Feature Elimination (RFE)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('='*80)\nprint('RECURSIVE FEATURE ELIMINATION (RFE)')\nprint('='*80)\n\n# Use Gradient Boosting as the estimator\nprint('\\nTraining GB estimator for RFE...')\ngb_rfe = GradientBoostingClassifier(n_estimators=100, max_leaf_nodes=10, \n                                     learning_rate=0.1, random_state=42, verbose=0)\n\n# RFE to select top 15 features\nn_features_to_select = 15\nprint(f'Selecting top {n_features_to_select} features...')\n\nrfe = RFE(estimator=gb_rfe, n_features_to_select=n_features_to_select, step=1)\nrfe.fit(X_train, y_train)\n\n# Get selected features\nselected_features = X_train.columns[rfe.support_].tolist()\nfeature_ranking = pd.DataFrame({\n    'feature': X_train.columns,\n    'rank': rfe.ranking_,\n    'selected': rfe.support_\n}).sort_values('rank')\n\nprint(f'\\nSelected {len(selected_features)} features:')\nfor i, feat in enumerate(selected_features, 1):\n    print(f'  {i}. {feat}')\n\nprint(f'\\nAll features ranked by importance:')\nprint(feature_ranking.head(20).to_string(index=False))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Reduce datasets to selected features\nX_train_rfe = X_train[selected_features]\nX_test_rfe = X_test[selected_features]\n\ndf_train_rfe = df_train_set[selected_features + ['loan_default']].copy()\ndf_test_rfe = df_test_set[selected_features + ['loan_default']].copy()\n\nprint(f'\\nReduced feature sets:')\nprint(f'  Training: {X_train_rfe.shape}')\nprint(f'  Test: {X_test_rfe.shape}')\nprint(f'  Features reduced from {X_train.shape[1]} to {X_train_rfe.shape[1]}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Step 6: Train Models with Selected Features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('='*80)\nprint('MODEL TRAINING WITH SELECTED FEATURES')\nprint('='*80)\n\n# Logistic Regression\nprint('\\nTraining Logistic Regression...')\nlr = LogisticRegression(max_iter=1000, random_state=42, n_jobs=-1)\nlr.fit(X_train_rfe, y_train)\n\ndf_train_rfe['pred_lr'] = lr.predict_proba(X_train_rfe)[:, 1]\ndf_test_rfe['pred_lr'] = lr.predict_proba(X_test_rfe)[:, 1]\n\nauc_train_lr = roc_auc_score(y_train, df_train_rfe['pred_lr'])\nauc_test_lr = roc_auc_score(y_test, df_test_rfe['pred_lr'])\nprint(f'  Train AUC: {auc_train_lr:.4f}')\nprint(f'  Test AUC: {auc_test_lr:.4f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Gradient Boosting\nprint('Training Gradient Boosting...')\ngb = GradientBoostingClassifier(\n    n_estimators=100, max_leaf_nodes=10, learning_rate=0.1,\n    min_samples_leaf=0.05, random_state=42\n)\ngb.fit(X_train_rfe, y_train)\n\ndf_train_rfe['pred_gb'] = gb.predict_proba(X_train_rfe)[:, 1]\ndf_test_rfe['pred_gb'] = gb.predict_proba(X_test_rfe)[:, 1]\n\nauc_train_gb = roc_auc_score(y_train, df_train_rfe['pred_gb'])\nauc_test_gb = roc_auc_score(y_test, df_test_rfe['pred_gb'])\nprint(f'  Train AUC: {auc_train_gb:.4f}')\nprint(f'  Test AUC: {auc_test_gb:.4f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Step 7: Model Comparison"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('\\n' + '='*80)\nprint('MODEL COMPARISON')\nprint('='*80)\n\ncomparison = pd.DataFrame({\n    'Model': ['Logistic Regression', 'Gradient Boosting'],\n    'Train AUC': [auc_train_lr, auc_train_gb],\n    'Test AUC': [auc_test_lr, auc_test_gb],\n    'Overfit Gap': [abs(auc_train_lr - auc_test_lr), abs(auc_train_gb - auc_test_gb)]\n})\nprint('\\n' + comparison.round(4).to_string(index=False))\n\nbest_idx = 0 if auc_test_lr > auc_test_gb else 1\nbest_name = ['Logistic Regression', 'Gradient Boosting'][best_idx]\nbest_model = [lr, gb][best_idx]\nbest_pred_col = ['pred_lr', 'pred_gb'][best_idx]\nbest_auc = max(auc_test_lr, auc_test_gb)\n\nprint(f'\\n✓ BEST MODEL: {best_name}')\nprint(f'  Test AUC: {best_auc:.4f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Step 8: Performance Metrics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def show_metrics(y_true, y_pred_prob, name='Test'):\n    y_pred = (y_pred_prob > 0.5).astype(int)\n    cm = confusion_matrix(y_true, y_pred)\n    \n    print(f'\\n{name} Set Metrics:')\n    print(f'  Accuracy: {accuracy_score(y_true, y_pred):.4f}')\n    print(f'  Balanced Accuracy: {balanced_accuracy_score(y_true, y_pred):.4f}')\n    print(f'  Precision: {precision_score(y_true, y_pred):.4f}')\n    print(f'  Recall: {recall_score(y_true, y_pred):.4f}')\n    print(f'  ROC-AUC: {roc_auc_score(y_true, y_pred_prob):.4f}')\n    print(f'  Confusion Matrix:')\n    print(f'    TN: {cm[0,0]:,}  FP: {cm[0,1]:,}')\n    print(f'    FN: {cm[1,0]:,}  TP: {cm[1,1]:,}')\n\nprint('='*80)\nprint(f'{best_name.upper()} - PERFORMANCE METRICS')\nprint('='*80)\nshow_metrics(y_train, df_train_rfe[best_pred_col], 'Train')\nshow_metrics(y_test, df_test_rfe[best_pred_col], 'Test')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Step 9: Time Series - Actual vs Predicted by Period"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def plot_calibration(df_data, pred_col, actual_col, title='Test', n_periods=10):\n    df_temp = df_data.copy()\n    df_temp['period'] = pd.qcut(range(len(df_temp)), q=n_periods,\n                                 labels=[f'P{i+1}' for i in range(n_periods)])\n    \n    ts = df_temp.groupby('period').agg({\n        actual_col: 'mean',\n        pred_col: 'mean'\n    })\n    \n    ts['actual_pct'] = ts[actual_col] * 100\n    ts['pred_pct'] = ts[pred_col] * 100\n    ts['deviation'] = abs(ts['actual_pct'] - ts['pred_pct'])\n    \n    # Plot\n    fig, ax = plt.subplots(figsize=(14, 6))\n    x = range(len(ts))\n    \n    ax.plot(x, ts['actual_pct'], marker='o', linewidth=2.5, markersize=8,\n            label='Actual Default Rate', color='#d62728')\n    ax.plot(x, ts['pred_pct'], marker='s', linewidth=2.5, markersize=8,\n            label='Predicted Default Rate', color='#1f77b4')\n    \n    ax.set_xlabel('Period', fontsize=12, fontweight='bold')\n    ax.set_ylabel('Default Rate (%)', fontsize=12, fontweight='bold')\n    ax.set_title(f'{title} Set: Actual vs Predicted Default Rates', fontsize=14, fontweight='bold')\n    ax.set_xticks(x)\n    ax.set_xticklabels(ts.index)\n    ax.legend(fontsize=11)\n    ax.grid(True, alpha=0.3)\n    plt.tight_layout()\n    plt.show()\n    \n    # Metrics\n    mae = ts['deviation'].mean()\n    max_dev = ts['deviation'].max()\n    print(f'{title} Calibration:')\n    print(f'  MAE: {mae:.2f}%')\n    print(f'  Max Deviation: {max_dev:.2f}%')\n    print(f'\\nPeriod Details:')\n    print(ts[['actual_pct', 'pred_pct', 'deviation']].round(2).to_string())\n\nprint('='*80)\nprint('TIME SERIES CALIBRATION - ACTUAL vs PREDICTED')\nprint('='*80)\nprint('\\nTRAINING DATA:')\nplot_calibration(df_train_rfe, best_pred_col, 'loan_default', 'Training')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('\\nTEST DATA:')\nplot_calibration(df_test_rfe, best_pred_col, 'loan_default', 'Test')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Step 10: Feature Importance"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('='*80)\nprint('FEATURE IMPORTANCE - TOP SELECTED FEATURES')\nprint('='*80)\n\nif best_idx == 1:  # GB\n    feature_importance = pd.DataFrame({\n        'feature': selected_features,\n        'importance': best_model.feature_importances_\n    }).sort_values('importance', ascending=False)\n    \n    print(f'\\nAll {len(feature_importance)} selected features ranked by importance:')\n    print(feature_importance.round(4).to_string(index=False))\n    \n    # Plot\n    fig, ax = plt.subplots(figsize=(12, 8))\n    feature_importance.sort_values('importance').plot(\n        kind='barh', x='feature', y='importance', ax=ax, legend=False\n    )\n    ax.set_xlabel('Importance', fontsize=12, fontweight='bold')\n    ax.set_ylabel('Feature', fontsize=12, fontweight='bold')\n    ax.set_title('Feature Importance (Selected Features)', fontsize=14, fontweight='bold')\n    plt.tight_layout()\n    plt.show()\nelse:  # LR\n    feature_importance = pd.DataFrame({\n        'feature': selected_features,\n        'coefficient': abs(best_model.coef_[0])\n    }).sort_values('coefficient', ascending=False)\n    \n    print(f'\\nAll {len(feature_importance)} selected features ranked by coefficient magnitude:')\n    print(feature_importance.round(4).to_string(index=False))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Step 11: Score Holdout Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Prepare holdout\nX_holdout = df_holdout_final.drop(\n    columns=[c for c in df_holdout_final.columns if c in ['Restaurant_ID', 'Tx_date'] or \n             'Ownership' in c or 'catagory' in c or 'segment' in c]\n)\n\n# Add categorical dummies\nfor col in ['Ownership_type', 'Restaurant_catagory', 'Market_segment']:\n    if col in df_holdout_final.columns:\n        dummies = pd.get_dummies(df_holdout_final[col], prefix=col)\n        X_holdout = pd.concat([X_holdout, dummies], axis=1)\n\n# Align with training features\nfor col in selected_features:\n    if col not in X_holdout.columns:\n        X_holdout[col] = 0\nX_holdout = X_holdout[selected_features]\n\n# Score\nholdo_pred = best_model.predict_proba(X_holdout)[:, 1]\n\n# Results\nresults = pd.DataFrame({\n    'Restaurant_ID': df_holdout_final['Restaurant_ID'].values,\n    'Predicted_Default_Probability': np.round(holdout_pred, 4),\n    'Predicted_Default_Score_0_100': np.round(holdout_pred * 100, 2)\n})\n\n# Save\nresults.to_csv('holdout_predictions_final.csv', index=False)\n\nprint('='*80)\nprint(f'HOLDOUT SCORING - {best_name} with RFE')\nprint('='*80)\nprint(f'Total records: {len(results):,}')\nprint(f'\\nPrediction Statistics:')\nprint(results['Predicted_Default_Probability'].describe().round(4))\nprint(f'\\nFirst 10 predictions:')\nprint(results.head(10).to_string(index=False))\nprint(f'\\n✓ Saved to holdout_predictions_final.csv')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Step 12: Holdout Distribution"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "results_with_decile = results.copy()\n",
