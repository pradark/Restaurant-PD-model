    "fig = plt.figure(figsize=(18, 12))\ngs = fig.add_gridspec(3, 3, hspace=0.35, wspace=0.3)\n\n# Figure 1: AUC Comparison\nax1 = fig.add_subplot(gs[0, 0])\nmetrics_names = ['Train AUC', 'Test AUC']\niv_vals = [auc_train_iv, auc_test_iv]\nrfecv_vals = [auc_train_rfecv, auc_test_rfecv]\nx = np.arange(len(metrics_names))\nwidth = 0.35\nax1.bar(x - width/2, iv_vals, width, label='IV-Based', color='#2E86AB', alpha=0.85, edgecolor='black', linewidth=2)\nax1.bar(x + width/2, rfecv_vals, width, label='RFECV', color='#A23B72', alpha=0.85, edgecolor='black', linewidth=2)\nax1.set_ylabel('AUC Score', fontsize=11, fontweight='bold')\nax1.set_title('AUC Comparison', fontsize=12, fontweight='bold')\nax1.set_xticks(x)\nax1.set_xticklabels(metrics_names)\nax1.set_ylim([0.75, 0.85])\nax1.legend()\nax1.grid(axis='y', alpha=0.3)\nfor i, (v1, v2) in enumerate(zip(iv_vals, rfecv_vals)):\n    ax1.text(i - width/2, v1 + 0.002, f'{v1:.4f}', ha='center', va='bottom', fontsize=9, fontweight='bold')\n    ax1.text(i + width/2, v2 + 0.002, f'{v2:.4f}', ha='center', va='bottom', fontsize=9, fontweight='bold')\n\n# Figure 2: K-S and Gini\nax2 = fig.add_subplot(gs[0, 1])\nmetrics_ks = ['K-S', 'Gini']\niv_ks = [metrics_iv['K-S'], metrics_iv['Gini']]\nrfecv_ks = [metrics_rfecv['K-S'], metrics_rfecv['Gini']]\nx = np.arange(len(metrics_ks))\nax2.bar(x - width/2, iv_ks, width, label='IV-Based', color='#2E86AB', alpha=0.85, edgecolor='black', linewidth=2)\nax2.bar(x + width/2, rfecv_ks, width, label='RFECV', color='#A23B72', alpha=0.85, edgecolor='black', linewidth=2)\nax2.set_ylabel('Score', fontsize=11, fontweight='bold')\nax2.set_title('K-S & Gini Comparison', fontsize=12, fontweight='bold')\nax2.set_xticks(x)\nax2.set_xticklabels(metrics_ks)\nax2.legend()\nax2.grid(axis='y', alpha=0.3)\nfor i, (v1, v2) in enumerate(zip(iv_ks, rfecv_ks)):\n    ax2.text(i - width/2, v1 + 0.01, f'{v1:.3f}', ha='center', va='bottom', fontsize=9, fontweight='bold')\n    ax2.text(i + width/2, v2 + 0.01, f'{v2:.3f}', ha='center', va='bottom', fontsize=9, fontweight='bold')\n\n# Figure 3: Feature Count\nax3 = fig.add_subplot(gs[0, 2])\nfeature_data = [len(selected_iv), len(selected_rfecv)]\nlabels = [f'IV-Based\\n({len(selected_iv)})', f'RFECV\\n({len(selected_rfecv)})']\ncolors = ['#2E86AB', '#A23B72']\nbars = ax3.bar(labels, feature_data, color=colors, alpha=0.85, edgecolor='black', linewidth=2, width=0.6)\nax3.set_ylabel('Number of Features', fontsize=11, fontweight='bold')\nax3.set_title('Feature Count Comparison', fontsize=12, fontweight='bold')\nax3.grid(axis='y', alpha=0.3)\nfor bar, val in zip(bars, feature_data):\n    ax3.text(bar.get_x() + bar.get_width()/2., val + 0.5, f'{int(val)}', ha='center', va='bottom', fontsize=10, fontweight='bold')\n\n# Figure 4: ROC Curves\nax4 = fig.add_subplot(gs[1, 0])\nfpr_iv, tpr_iv, _ = roc_curve(y_test, y_pred_test_iv)\nfpr_rfecv, tpr_rfecv, _ = roc_curve(y_test, y_pred_test_rfecv)\nax4.plot([0, 1], [0, 1], 'k--', alpha=0.3, linewidth=1.5)\nax4.plot(fpr_iv, tpr_iv, linewidth=2.5, label=f'IV-Based (AUC={auc_test_iv:.4f})', color='#2E86AB')\nax4.plot(fpr_rfecv, tpr_rfecv, linewidth=2.5, label=f'RFECV (AUC={auc_test_rfecv:.4f})', color='#A23B72')\nax4.set_xlabel('False Positive Rate', fontsize=11, fontweight='bold')\nax4.set_ylabel('True Positive Rate', fontsize=11, fontweight='bold')\nax4.set_title('ROC Curves (Test Set)', fontsize=12, fontweight='bold')\nax4.legend(fontsize=10)\nax4.grid(alpha=0.3)\n\n# Figure 5: Sensitivity vs Specificity\nax5 = fig.add_subplot(gs[1, 1])\nmetrics_perf = ['Sensitivity', 'Specificity']\niv_perf = [metrics_iv['Sensitivity'], metrics_iv['Specificity']]\nrfecv_perf = [metrics_rfecv['Sensitivity'], metrics_rfecv['Specificity']]\nx = np.arange(len(metrics_perf))\nax5.bar(x - width/2, iv_perf, width, label='IV-Based', color='#2E86AB', alpha=0.85, edgecolor='black', linewidth=2)\nax5.bar(x + width/2, rfecv_perf, width, label='RFECV', color='#A23B72', alpha=0.85, edgecolor='black', linewidth=2)\nax5.set_ylabel('Score', fontsize=11, fontweight='bold')\nax5.set_title('Sensitivity vs Specificity', fontsize=12, fontweight='bold')\nax5.set_xticks(x)\nax5.set_xticklabels(metrics_perf)\nax5.set_ylim([0, 1])\nax5.legend()\nax5.grid(axis='y', alpha=0.3)\nfor i, (v1, v2) in enumerate(zip(iv_perf, rfecv_perf)):\n    ax5.text(i - width/2, v1 + 0.02, f'{v1:.3f}', ha='center', va='bottom', fontsize=9, fontweight='bold')\n    ax5.text(i + width/2, v2 + 0.02, f'{v2:.3f}', ha='center', va='bottom', fontsize=9, fontweight='bold')\n\n# Figure 6: Calibration Error\nax6 = fig.add_subplot(gs[1, 2])\ncal_labels = ['IV-Based', 'RFECV']\ncal_maes = [mae_iv, mae_rfecv]\nbars = ax6.bar(cal_labels, cal_maes, color=['#2E86AB', '#A23B72'], alpha=0.85, edgecolor='black', linewidth=2, width=0.6)\nax6.set_ylabel('Mean Absolute Error', fontsize=11, fontweight='bold')\nax6.set_title('Calibration Error (MAE)', fontsize=12, fontweight='bold')\nax6.grid(axis='y', alpha=0.3)\nfor bar, val in zip(bars, cal_maes):\n    ax6.text(bar.get_x() + bar.get_width()/2., val + 0.0005, f'{val:.4f}', ha='center', va='bottom', fontsize=10, fontweight='bold')\n\n# Figure 7: Calibration Curves\nax7 = fig.add_subplot(gs[2, 0])\nax7.plot(cal_iv['Predicted_Rate'], cal_iv['Actual_Rate'], 'o-', linewidth=2, markersize=7, label='IV-Based', color='#2E86AB')\nax7.plot(cal_rfecv['Predicted_Rate'], cal_rfecv['Actual_Rate'], 's-', linewidth=2, markersize=7, label='RFECV', color='#A23B72')\nax7.plot([0, 0.5], [0, 0.5], 'k--', alpha=0.3, label='Perfect Calibration')\nax7.set_xlabel('Predicted Rate', fontsize=11, fontweight='bold')\nax7.set_ylabel('Actual Rate', fontsize=11, fontweight='bold')\nax7.set_title('Calibration Curve by Decile', fontsize=12, fontweight='bold')\nax7.legend(fontsize=10)\nax7.grid(alpha=0.3)\n\n# Figure 8: Confusion Matrices\nax8 = fig.add_subplot(gs[2, 1])\ncm_iv = [[metrics_iv['TN'], metrics_iv['FP']], [metrics_iv['FN'], metrics_iv['TP']]]\nim = ax8.imshow(cm_iv, cmap='Blues', aspect='auto')\nax8.set_xticks([0, 1])\nax8.set_yticks([0, 1])\nax8.set_xticklabels(['Non-Default', 'Default'])\nax8.set_yticklabels(['Non-Default', 'Default'])\nfor i in range(2):\n    for j in range(2):\n        ax8.text(j, i, str(cm_iv[i][j]), ha='center', va='center', color='white' if cm_iv[i][j] > 1000 else 'black', fontsize=12, fontweight='bold')\nax8.set_title('Confusion Matrix (IV-Based)', fontsize=12, fontweight='bold')\n\nax9 = fig.add_subplot(gs[2, 2])\ncm_rfecv = [[metrics_rfecv['TN'], metrics_rfecv['FP']], [metrics_rfecv['FN'], metrics_rfecv['TP']]]\nim = ax9.imshow(cm_rfecv, cmap='RdPu', aspect='auto')\nax9.set_xticks([0, 1])\nax9.set_yticks([0, 1])\nax9.set_xticklabels(['Non-Default', 'Default'])\nax9.set_yticklabels(['Non-Default', 'Default'])\nfor i in range(2):\n    for j in range(2):\n        ax9.text(j, i, str(cm_rfecv[i][j]), ha='center', va='center', color='white' if cm_rfecv[i][j] > 1000 else 'black', fontsize=12, fontweight='bold')\nax9.set_title('Confusion Matrix (RFECV)', fontsize=12, fontweight='bold')\n\nplt.suptitle('Comprehensive Performance Comparison: IV-Based vs RFECV Feature Selection', fontsize=16, fontweight='bold', y=0.995)\nplt.tight_layout()\nplt.show()\n\nprint(\"✓ All comparison visualizations created\")"
