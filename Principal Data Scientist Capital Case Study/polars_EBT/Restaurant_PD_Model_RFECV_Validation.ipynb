    "## SECTION 11: Calibration Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"[STEP 11] Calibration Analysis by Decile\\n\")\n",
    "\n",
    "def decile_analysis(y_true, y_pred_proba):\n    deciles = np.percentile(y_pred_proba, np.linspace(0, 100, 11))\n    decile_groups = np.digitize(y_pred_proba, deciles) - 1\n    \n    cal_data = []\n    for decile in range(10):\n        mask = decile_groups == decile\n        if mask.sum() == 0:\n            continue\n        \n        n_obs = mask.sum()\n        n_def = y_true[mask].sum()\n        avg_pred = y_pred_proba[mask].mean()\n        actual_rate = y_true[mask].mean()\n        mae = abs(actual_rate - avg_pred)\n        \n        cal_data.append({\n            'Decile': decile + 1,\n            'N': n_obs,\n            'Defaults': int(n_def),\n            'Predicted_Rate': avg_pred,\n            'Actual_Rate': actual_rate,\n            'MAE': mae\n        })\n    \n    return pd.DataFrame(cal_data)\n\ncal_iv = decile_analysis(y_test, y_pred_test_iv)\ncal_rfecv = decile_analysis(y_test, y_pred_test_rfecv)\n\nmae_iv = cal_iv['MAE'].mean()\nmae_rfecv = cal_rfecv['MAE'].mean()\n\nprint(\"IV-BASED CALIBRATION:\")\nprint(cal_iv.to_string(index=False))\nprint(f\"\\nMean Absolute Calibration Error (MAE): {mae_iv:.4f}\")\n\nprint(f\"\\n\" + \"=\"*80)\nprint(\"\\nRFECV CALIBRATION:\")\nprint(cal_rfecv.to_string(index=False))\nprint(f\"\\nMean Absolute Calibration Error (MAE): {mae_rfecv:.4f}\")"
   ]
  },
